# Supabase Configuration
# Get these from your Supabase project settings > API
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Note: If you don't have Supabase credentials, the app will run in MOCK MODE
# which uses pre-built demo data and doesn't require authentication.
# To use real authentication and database features, add your Supabase credentials above.
